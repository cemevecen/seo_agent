# ── Google API ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8012/api/search-console/oauth/callback
# Railway: https://projectcontrol.up.railway.app/api/search-console/oauth/callback (Google Cloud → OAuth client → Authorized redirect URIs)
# Gmail gelen kutusu (/inbox): Aynı GOOGLE_CLIENT_ID ile ikinci redirect URI ekleyin (Google Cloud → OAuth client → Authorized redirect URIs).
# Örnek Railway: https://<senin-hostun>/api/inbox/oauth/callback
# Kapsamlar: gmail.modify + gmail.send (hassas; dahili Workspace hesabı önerilir).
GMAIL_INBOX_OAUTH_REDIRECT_URI=http://127.0.0.1:8012/api/inbox/oauth/callback
# Üyelik girişi (Google): /admin/login → Google ile giriş
# Railway: https://projectcontrol.up.railway.app/auth/google/callback
APP_MEMBER_OAUTH_REDIRECT_URI=http://127.0.0.1:8012/auth/google/callback
# Railway: https://projectcontrol.up.railway.app/api/inbox/oauth/callback (boş/localhost ise istek host'undan otomatik)
INBOX_OAUTH_LOGIN_HINT=cemevecen@nokta.com
# Hangi mailler indekslensin (Gmail arama sözdizimi): https://support.google.com/mail/answer/7190
INBOX_GMAIL_QUERY=(to:info@doviz.com OR to:feedback@doviz.com OR from:firebase-noreply@google.com OR from:firebase-noreply.googleapis.com)
# AI özet ve taslak için OpenAI (ChatGPT API) modeli — OPENAI_API_KEY gerekir.
INBOX_OPENAI_MODEL=gpt-4.1-mini

# ── Günlük AI özet (yalnızca bu özellik LLM çağırır; başka modül kullanmaz)
# Varsayılan: zamanlanmış LLM kapalı; yalnızca arayüzden POST /ai/generate (manuel). Otomatik için: AI_DAILY_BRIEF_ENABLED=true ve AI_DAILY_BRIEF_SCHEDULER_ENABLED=true
# En az biri: Groq, Gemini veya OpenAI. Varsayılan: gemini (günlük cron önce Gemini).
# auto: önce Gemini sonra Groq/OpenAI (failover ile).
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# AI_DAILY_BRIEF_PROVIDER=gemini
# AI_DAILY_BRIEF_PROVIDER=auto
# AI_DAILY_BRIEF_PROVIDER=openai
# Kalite: Gemini 2.5 Flash + Groq GPT-OSS 120B (API desteklemiyorsa Groq: llama-3.3-70b-versatile, Gemini: gemini-2.0-flash)
# AI_DAILY_BRIEF_GROQ_MODEL=openai/gpt-oss-120b
# AI_DAILY_BRIEF_GEMINI_MODEL=gemini-2.5-flash
# AI_DAILY_BRIEF_OPENAI_MODEL=gpt-4.1-mini
# Tek istekte üretim+Türkçe (önerilir): AI_DAILY_BRIEF_SINGLE_LLM_CALL=true
# 429/kota hatasında diğer anahtara düş: AI_DAILY_BRIEF_PROVIDER_FAILOVER=true
# İstanbul günü başına max LLM çağrısı (failover + ara sıra manuel için): AI_DAILY_BRIEF_MAX_LLM_CALLS_PER_CALENDAR_DAY=6
# Aylık tahmini harcama tavanı (TRY); 0=sadece günlük çağrı kotası: LLM_SPEND_BUDGET_TRY=100
# Token fiyatı kalibrasyonu (USD/M tok); Groq konsol / Google fiyatına göre: LLM_SPEND_USD_TO_TRY=35 LLM_GROQ_PROMPT_USD_PER_MTOK=0.15 LLM_GROQ_COMPLETION_USD_PER_MTOK=0.6
# Otomatik günlük cron (varsayılan kapalı): AI_DAILY_BRIEF_SCHEDULER_ENABLED=true
# Özet sonrası e-posta (varsayılan kapalı): AI_DAILY_BRIEF_SEND_EMAIL=true
# Zamanlanmış LLM job (varsayılan kapalı; manuel /ai/generate yine çalışır): AI_DAILY_BRIEF_ENABLED=true
# AI_DAILY_BRIEF_HOUR=6
# AI_DAILY_BRIEF_MINUTE=15
# AI_DAILY_BRIEF_TIMEZONE=Europe/Istanbul

# ── Veritabanı ──────────────────────────────────────────────────────────────
POSTGRES_DB=seo_agent
POSTGRES_USER=seo_agent
POSTGRES_PASSWORD=guclu_bir_sifre_gir
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://seo_agent:guclu_bir_sifre_gir@postgres:5432/seo_agent

# Opsiyonel: disk sıkışınca gecelik retention sürelerini kısalt (varsayılanlar: 30/60/90/30 gün)
# DB_RETENTION_COLLECTOR_RUN_DAYS=30
# DB_RETENTION_ALERT_LOG_DAYS=60
# DB_RETENTION_METRIC_DAYS=90
# Gecelik cleanup sonrası Postgres üzerinde tam VACUUM ANALYZE (varsayılan false; Railway'de genelde autovacuum yeterli)
# DB_RETENTION_RUN_VACUUM=true
# DB_RETENTION_NOTIFICATION_DELIVERY_DAYS=30

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── Uygulama güvenliği ───────────────────────────────────────────────────────
SECRET_KEY=cok_uzun_rastgele_bir_string_gir
ENCRYPTION_KEY=fernet_ile_uretilmis_key_gir

# ── İzin verilen IP'ler (virgülle; boş = hiç kimse allowlist sayılmaz, sadece admin şifresi) ──
ALLOWED_CLIENT_IPS=176.40.240.237,78.187.20.15
# Yerel geliştirme: 127.0.0.1’i de ekleyin veya şifre yokken tarayıcıdan doğrudan http://127.0.0.1:PORT/settings (loopback).
TRUST_PROXY_HEADERS=true
# Veritabanında admin hash yoksa açılışta bir kez bu değer yazılır (≥6 karakter). Sonra /settings’ten değişir.
# ADMIN_PASSWORD=
# IP allowlist + /admin girişi. Yerel geliştirmede kapatmak için: false. Railway (RAILWAY_*) üzerinde her zaman zorunludur, yok sayılır.
# ADMIN_AUTH_ENFORCED=false

# Tanınmayan admin girişi uyarısı (SMTP/Gmail OAuth gerekir)
# ADMIN_LOGIN_ALERT_EMAIL=cemevecen@nokta.com
# ADMIN_LOGIN_ALERT_ENABLED=true
# Girişten sonra menü gezintisini toplamak için uyarı gecikmesi (sn); 0 = anında
# ADMIN_LOGIN_ALERT_NAV_DELAY_SECONDS=90

# TMDB vizyon takvimi — misafir paylaşım linki (?access=…); yalnızca /tmdb-upcoming, admin şifresi gerekmez.
# Örnek: https://projectcontrol.up.railway.app/tmdb-upcoming?access=<bu-değer>
# TMDB_GUEST_ACCESS_TOKEN=

APP_HOST=0.0.0.0

# ── GA4 (Google Analytics Data API) ────────────────────────────────────────────
# Kimlik: yalnızca aşağıdakilerden biri (ikisi doluysa önce JSON string kullanılır).
GA4_SERVICE_ACCOUNT_FILE=keys/ga4-service-account.json
# Tek satırda tüm JSON (Railway/Kubernetes secret); yerelde genelde FILE yeterli.
GA4_SERVICE_ACCOUNT_JSON=
# Property / stream ID’leri arayüzden (Ayarlar) site bazında kaydedilir; .env’de property yok.
# Realtime «Haberler» sekmesi + GA4 landing «haber hariç» aynı path listesini kullanır (varsayılan config’te). URL sonu /123 gibi sayısal ID makale detayı sayılır.
# GA4_EXCLUDE_PATH_SUBSTRINGS=/haber/,/news/,/gundem/

# ── Firebase Crashlytics → BigQuery (okuma) ───────────────────────────────────
# GA4 ile aynı service account kullanılır; GCP’de bu hesaba BigQuery Data Viewer + BigQuery Job User verin.
# Proje id boşsa service account JSON içindeki project_id kullanılır (Firebase projesiyle aynı olmalı).
# FIREBASE_CRASHLYTICS_BIGQUERY_PROJECT=
# Varsayılan dataset adı genelde firebase_crashlytics (Firebase konsolunda aktarım sihirbazında görünür).
# FIREBASE_CRASHLYTICS_BIGQUERY_DATASET=firebase_crashlytics

# ── Search Console ───────────────────────────────────────────────────────────
GOOGLE_SEARCH_CONSOLE_CREDENTIALS_JSON=
# Çok hedefli (m+www) sitede "page" boyutu ek istekleri artırır; Railway timeout için kapatılabilir.
# SEARCH_CONSOLE_INCLUDE_PAGE_DIMENSION=false
# Sayfa raporlarında satır tavanı (düşük = daha az API / daha kısa süre).
# SEARCH_CONSOLE_PAGE_REPORT_ROW_CAP=800

# ── E-posta ──────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_TO=cemevecen@nokta.com
OPERATIONS_MAIL_TO=cemevecen@nokta.com
# 404 günlük raporu (13:15 / 23:15). Varsayılan cemevecen@nokta.com — OPERATIONS_MAIL_TO/MAIL_TO kullanılmaz.
# @gmail.com alıcıları kod tarafından otomatik çıkarılır; yalnız @nokta.com kullanın.
# ERROR_REPORT_MAIL_TO=cemevecen@nokta.com
# Tüm giden e-postalar (uyarı, operasyon özeti, AI/GA4 özet). true yapınca SMTP kullanılır.
OUTBOUND_EMAIL_ENABLED=false
# Yalnız operasyon/tetik özetleri; OUTBOUND_EMAIL_ENABLED=true iken True yapın.
OPERATIONS_TRIGGER_EMAIL_ENABLED=false
# true: giden mail yalnızca manuel tetiklerde (zamanlayıcı, GA4 günlük özet, kaçırılan job monitörü dahil değil). false: eski davranış (system mailleri açık).
EMAIL_MANUAL_TRIGGERS_ONLY=true

# SMTP günlük kota (tüm giden: outbound + GA4 Realtime). Gmail tüketici ~500 mesaj/gün; Workspace ücretli ~2000/gün (Google, değişebilir).
# Workspace SMTP ile mesaj başına çoğu senaryoda en fazla 100 alıcı (RCPT): https://support.google.com/a/answer/166852
# Tüketici Gmail: https://support.google.com/mail/answer/22839
# SMTP_DAILY_SEND_LIMIT=0 veya SMTP_DAILY_QUOTA_ENABLED=false → sayaç devre dışı.
# SMTP_DAILY_QUOTA_ENABLED=true
# SMTP_DAILY_SEND_LIMIT=450
# SMTP_QUOTA_CALENDAR_TIMEZONE=Europe/Istanbul
# SMTP_MAX_RECIPIENTS_PER_MESSAGE=100

# ── Zamanlayıcı ──────────────────────────────────────────────────────────────
SCHEDULED_REFRESH_TIMEZONE=Europe/Istanbul
SCHEDULER_HOUR_1=3
SCHEDULER_HOUR_2=5
SCHEDULER_HOUR_3=7

SEARCH_CONSOLE_SCHEDULED_REFRESH_ENABLED=true
SEARCH_CONSOLE_SCHEDULED_REFRESH_HOUR=4
SEARCH_CONSOLE_SCHEDULED_REFRESH_MINUTE=0
# Tam SC yenilemesinden önce bu siteye ait snapshot satırlarını sil (Railway: RAILWAY_ENVIRONMENT ile varsayılan açık)
# SEARCH_CONSOLE_PURGE_ON_RAILWAY=false
# Tüm ortamlarda zorla: SEARCH_CONSOLE_PURGE_BEFORE_COLLECT=true

SCHEDULED_REFRESH_ENABLED=true
# PageSpeed + Crawler + CrUX günlük job (Europe/Istanbul)
SCHEDULED_REFRESH_HOUR=7
SCHEDULED_REFRESH_MINUTE=0

GA4_SCHEDULED_REFRESH_ENABLED=true
GA4_SCHEDULED_REFRESH_HOUR=4
GA4_SCHEDULED_REFRESH_MINUTE=30
GA4_SCHEDULED_REFRESH_SITE_SPACING_SECONDS=15
# Gece GA4: virgülle KPI günleri + ayrı 12 ay günlük trend
# GA4_SCHEDULED_KPI_PERIOD_DAYS=1,7,30,60,90

# Inbox otomatik Gmail senkronu (e-posta göndermez)
# INBOX_SCHEDULED_SYNC_ENABLED=true
# INBOX_SCHEDULED_SYNC_INTERVAL_MINUTES=5
# INBOX_FIREBASE_SYNC_ENABLED=true
# INBOX_FIREBASE_SYNC_INTERVAL_MINUTES=5
# INBOX_STARTUP_SYNC_ENABLED=true
# INBOX_STARTUP_SYNC_DELAY_SECONDS=45

# GA4 Realtime monitoring (anlık karşılaştırma & alarm). Varsayılan kapalı.
# INTERVAL: APScheduler job (sunucu) dakika — snapshot + alarm. Tüm realtime alarmları
#   bu döngüde TEK mailde toplandığından, INTERVAL aynı zamanda "en erken X dk'da bir mail"
#   demektir. Sürekli mail gelmemesi için 30 önerilir.
# WINDOW: KPI karşılaştırma penceresi (dk). Daha büyük = daha birikmiş/sakin veri, daha az
#   yanlış alarm. 60 önerilir (30+30 yarı).
# UI_POLL: Realtime sayfası açıkken tarayıcının GA4’e gitme aralığı (saniye); 15–600.
GA4_REALTIME_ENABLED=false
GA4_REALTIME_INTERVAL_MINUTES=45
GA4_REALTIME_UI_POLL_SECONDS=45
GA4_REALTIME_WINDOW_MINUTES=60
# Realtime alarm e-postaları (site + sayfa): OUTBOUND_EMAIL_ENABLED / günlük özetlerden bağımsız; SMTP + MAIL_TO gerekir.
GA4_REALTIME_EMAIL_ENABLED=true
# Eski bayrak: ikisi de true iken posta gider; yalnızca realtime kanalını kapatmak için EMAIL=false yeterli.
GA4_REALTIME_PAGE_ALERT_EMAIL=true
# Haberler (Realtime): önceki snapshot ile karşılaştırma; kontrol en az INTERVAL dakikada (GA çağrısı).
GA4_REALTIME_NEWS_ALERTS_ENABLED=true
GA4_REALTIME_NEWS_ALERT_INTERVAL_MINUTES=15
GA4_REALTIME_NEWS_ALERT_WINDOW_MINUTES=15
GA4_REALTIME_NEWS_ALERT_EMAIL=true
# Aynı site/kural için mail tekrar baskılama (dk). 90 = daha az kirlilik.
# GA4_REALTIME_ALARM_EMAIL_COOLDOWN_MINUTES=90
# Konsolide «SEO Realtime: N alarm» maili en az bu kadar dk arayla (404 kritik hariç).
# GA4_REALTIME_EMAIL_BATCH_INTERVAL_MINUTES=60
# Sayfa/haber düşüşü postası: en az kullanıcı + mutlak fark (24→3 gibi gürültü elenir).
# GA4_REALTIME_EMAIL_MIN_USERS_FOR_MAIL=30
# GA4_REALTIME_EMAIL_MIN_ABS_USER_DELTA=12
# Tek mailde en fazla site/profil bölümü; fazlası /realtime’da kalır.
# GA4_REALTIME_EMAIL_BATCH_MAX_SECTIONS=8
# Realtime «Haberler» sekmesi: unifiedScreenName bu öneklerle başlıyorsa elenir (virgülle, küçük harf). Boş = yerleşik döviz/sinema araç sayfası listesi.
# GA4_REALTIME_NEWS_SCREEN_EXCLUDE_PREFIXES=canlı döviz,canlı gram

ALERTS_SCHEDULED_REFRESH_ENABLED=false
ALERTS_SCHEDULED_REFRESH_HOUR=4
ALERTS_SCHEDULED_REFRESH_MINUTE=0

SCHEDULED_REFRESH_MONITOR_ENABLED=true
SCHEDULED_REFRESH_MONITOR_INTERVAL_MINUTES=15
SCHEDULED_REFRESH_MONITOR_GRACE_MINUTES=45

# Döviz banka altını / varlık kaybı (katalog + fiyat tablosu; web/app aynı feed)
# DOVIZ_ASSET_MONITOR_ENABLED=true
# DOVIZ_ASSET_MONITOR_INTERVAL_MINUTES=30
# DOVIZ_ASSET_MONITOR_EMAIL_ENABLED=true
# DOVIZ_ASSET_MONITOR_CATALOG_URL=https://altin.doviz.com/
# DOVIZ_ASSET_MONITOR_PROBE_HOSTS=m.doviz.com,altin.doviz.com
# DOVIZ_ASSET_MONITOR_EXTRA_SLUGS=kuveyt-turk
# DOVIZ_ASSET_MONITOR_EXCLUDE_SLUGS=merkez-bankasi
# DOVIZ_ASSET_MONITOR_OPEN_ISSUES_EMAIL=false
# DOVIZ_ASSET_MONITOR_EMAIL_COOLDOWN_HOURS=1
# CSV manifest (panelden yükleme → DB → saatlik tarama)
# DOVIZ_ASSET_CSV_MANIFEST_ENABLED=true
# DOVIZ_ASSET_CSV_MANIFEST_INTERVAL_MINUTES=60
# DOVIZ_ASSET_CSV_MANIFEST_WORKERS=10
# DOVIZ_ASSET_CSV_MANIFEST_FETCH_TIMEOUT=15
# DOVIZ_ASSET_CSV_MANIFEST_MAX_EMAILS_PER_ISSUE=2

# ── Kota / Rate limiting ──────────────────────────────────────────────────────
QUOTA_GUARD_ENABLED=true
QUOTA_WARNING_RATIO=0.8
PAGESPEED_DAILY_LIMIT=80
PAGESPEED_MONTHLY_LIMIT=1500
# Data Explorer ve tam site manuel yenilemede günlük/aylık kota sayacını atla (Google API yine tüketilir). false = kota dolunca 429.
PAGESPEED_MANUAL_REFRESH_BYPASS_QUOTA=true
PAGESPEED_REQUEST_TIMEOUT=75
PAGESPEED_MAX_RETRIES=2
PAGESPEED_RETRY_BACKOFF_SECONDS=2.0
SEARCH_CONSOLE_DAILY_LIMIT=80
SEARCH_CONSOLE_MONTHLY_LIMIT=1500

# ── App Store Connect API (/app → App Store Connect paneli) ─────────────────
# Users and Access → Keys → App Store Connect API (JWT .p8 içeriği tek satır veya \\n ile)
# ASC_KEY_ID=
# ASC_ISSUER_ID=
# ASC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# Sales & Trends indirme/gelir için Payments and Financial Reports → Vendor Number
# ASC_VENDOR_NUMBER=
# Analytics Reports: Sales and Reports veya Admin rolü; ONGOING istek ilk kez 1–2 gün sürebilir

# ── App Intel (Play kategori sırası) ───────────────────────────────────────────
# Play headless çoğu ortamda ~50–75 uygulama sonrası durur; doğrulanmış sıra için (ör. mağaza ekranı):
# APP_INTEL_ANDROID_RANK_OVERRIDES={"doviz":161}
# Railway’de tam otomatik sıra için: APP_INTEL_ALLOW_PLAYWRIGHT_ON_RAILWAY=1 (süre maliyeti)

# ── Live refresh (uptime ping + otomatik sayfa yükü ölçümleri) ───────────────
# false iken: otomatik dashboard/site-detail PageSpeed tetikleri kapalı kalır;
# manuel "PSI + CrUX Yenile" ve POST /api/site/.../refresh (force) yine PageSpeed toplar.
LIVE_REFRESH_ENABLED=true
LIVE_REFRESH_METHOD=GET
LIVE_REFRESH_TIMEOUT=8
LIVE_REFRESH_URLS=http://app:8012/health,http://app:8012/
